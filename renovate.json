{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "forkProcessing": "enabled",
  "enabledManagers": ["npm", "github-actions"],
  "prConcurrentLimit": 30,
  "prHourlyLimit": 30,
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "postUpgradeTasks": {
        "commands": ["make generate"],
        "executionMode": "update"
      }
    }
  ]
}